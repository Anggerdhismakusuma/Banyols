<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_main"
        android:paddingVertical="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="D'CLASSICS\nTHE ARCHIVE"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/text_maroon"
            android:layout_gravity="center"/>
    </androidx.appcompat.widget.Toolbar>

    <!-- TAB -->
    <LinearLayout
        android:id="@+id/tabContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/tabFiction"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FICTION"
            android:gravity="center"
            android:padding="12dp"
            android:textColor="@color/text_maroon"
            android:textStyle="bold"
            android:background="@drawable/tab_indicator_line"/>

        <TextView
            android:id="@+id/tabNonFiction"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="NON-FICTION"
            android:gravity="center"
            android:padding="12dp"
            android:textColor="@color/text_grey"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- VIEWPAGER -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerBooks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
